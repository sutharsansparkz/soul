# LLM
# Set OPENAI_API_KEY to your key. Works with OpenAI and any compatible API.
OPENAI_API_KEY=
# Optional: override the API endpoint for OpenAI-compatible providers.
# Examples:
#   Ollama (local):        OPENAI_BASE_URL=http://localhost:11434/v1
#   LM Studio (local):     OPENAI_BASE_URL=http://localhost:1234/v1
#   Together AI:           OPENAI_BASE_URL=https://api.together.xyz/v1
#   Azure OpenAI:          OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
# Leave unset to use the default OpenAI endpoint.
OPENAI_BASE_URL=

# Database
DATABASE_URL=sqlite:///./soul_data/db/soul.db
SOUL_DATA_DIR=./soul_data

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=soul

# Memory retrieval (SQLite FTS5 is built-in)
# Hybrid search (optional - runs locally, no API key, no extra service)
# Install with: pip install -e '.[hybrid]'
HYBRID_EMBEDDINGS=false
HYBRID_MODEL=all-MiniLM-L6-v2

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_STABILITY=0.5
ELEVENLABS_VOICE_SIMILARITY_BOOST=0.5
VOICE_TRANSCRIPTION_MODEL=base
VOICE_PLAYBACK_TIMEOUT=60

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT=10

# Behaviour
# Model name passed to the API. Change to match your provider's model names.
# OpenAI examples:  gpt-4o, gpt-4o-mini, gpt-4-turbo
# Ollama examples:  llama3, mistral, phi3
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.8
MEMORY_RETRIEVAL_K=5
MEMORY_CANDIDATE_K=20
CONTEXT_HISTORY_LIMIT=12
HMS_SEMANTIC_WEIGHT=0.55
HMS_SCORE_WEIGHT=0.45
HMS_DECAY_HALFLIFE_DAYS=30
# Memories with hms_score below this value move to cold tier (never surface passively)
HMS_COLD_THRESHOLD=0.05
DRIFT_ENABLED=true
# Personality drift and rendering
PERSONALITY_DRIFT_BASELINE=0.5
PERSONALITY_DRIFT_RENDER_THRESHOLD=0.04
DRIFT_SIGNAL_LOOKBACK_DAYS=30
DRIFT_SIGNAL_SESSION_LIMIT=50
DRIFT_SIGNAL_ENGAGEMENT_DIVISOR=35
DRIFT_SIGNAL_MOOD_BONUS=0.15
DRIFT_SIGNAL_RESPONSE_LENGTH_MIN_WORDS=35
DRIFT_SIGNAL_USER_DEPTH_MIN_WORDS=20
DRIFT_SIGNAL_DIRECTNESS_REPLY_MAX_WORDS=30
DRIFT_SIGNAL_DIRECTNESS_USER_MIN_WORDS=15
DRIFT_SIGNAL_LONG_REPLY_MIN_WORDS=60
DRIFT_SIGNAL_RESPONSE_LENGTH_PENALTY=0.1
DRIFT_SIGNAL_DIRECTNESS_BONUS=0.4
DRIFT_SIGNAL_DIRECTNESS_PENALTY=0.2
# Mood classification (uses OpenAI, same key, no extra dependencies or downloads)
MOOD_OPENAI_MODEL=gpt-4o-mini
MOOD_OPENAI_MAX_TOKENS=60
MOOD_OPENAI_TEMPERATURE=0.0
MOOD_PRESERVE_PREVIOUS_MAX_WORDS=4
# HTTP timeouts
TELEGRAM_HTTP_TIMEOUT=15
TELEGRAM_LONGPOLL_EXTRA_SECONDS=20
ELEVENLABS_HTTP_TIMEOUT=30
# Personality drift caps
DRIFT_MAX_DEVIATION=0.20
DRIFT_WEEKLY_RATE=0.01
# Presence and proactive prompts
CHAT_PENDING_REACH_OUT_LIMIT=1
PRESENCE_STRESS_WINDOW_DAYS=14
PRESENCE_MILESTONE_SCAN_LIMIT=200
PROACTIVE_SILENCE_DAYS=3
PROACTIVE_STRESS_FOLLOWUP_DAYS=3
PROACTIVE_UPCOMING_EVENT_DAYS=7
# Memory and reflection automation
AUTO_MEMORY_CAPTURE_MOODS=["venting","reflective","celebrating","stressed","overwhelmed"]
AUTO_MEMORY_MIN_WORDS=8
AUTO_MEMORY_IMPORTANCE=0.65
SESSION_MEMORY_CHUNK_SIZE=3
SESSION_MEMORY_BASE_IMPORTANCE=0.55
SESSION_MEMORY_WORD_IMPORTANCE_CAP=0.2
SESSION_MEMORY_WORD_IMPORTANCE_DIVISOR=200
SESSION_MEMORY_MAX_IMPORTANCE=0.85
REFLECTION_RECENT_ITEMS_LIMIT=5
REFLECTION_MEMORY_IMPORTANCE=0.7
# Milestones and phrase detection
MILESTONE_MESSAGE_COUNT=100
MILESTONE_STREAK_DAYS=7
MILESTONE_ONE_MONTH_DAYS=30
MILESTONE_THREE_MONTH_DAYS=90
VULNERABILITY_TRIGGER_PHRASES=["i'm scared","i am scared","i feel invisible","i feel alone","i feel broken"]
SHARED_LANGUAGE_TRIGGERS={"as always":"recurring reassurance","late night coding":"favorite ritual","rough day":"shared shorthand for a hard day"}
MOOD_DECAY_HOURS=18
RAW_RETENTION_DAYS=90
SOUL_USER_ID=local-user
SOUL_TIMEZONE=UTC
ENVIRONMENT=development
