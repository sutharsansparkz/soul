# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database
DATABASE_URL=sqlite:///./soul_data/db/soul.db
SOUL_DATA_DIR=./soul_data
# DATABASE_URL=postgresql+psycopg://soul:soul@localhost:5432/soul

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=soul

# Chroma
CHROMA_PATH=./soul_data/chroma
CHROMA_ENABLED=false
# CHROMA_HOST=localhost:8000

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behaviour
LLM_MODEL=claude-sonnet-4-6
FALLBACK_LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
MEMORY_RETRIEVAL_K=5
DRIFT_ENABLED=true
MOOD_MODEL_ENABLED=false
MOOD_MODEL_NAME=cardiffnlp/twitter-roberta-base-emotion
MOOD_DECAY_HOURS=18
RAW_RETENTION_DAYS=90
SOUL_USER_ID=local-user
SOUL_TIMEZONE=Asia/Calcutta
ENVIRONMENT=development
