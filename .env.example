
# SOUL minimal .env for OpenAI-compatible LLM and mood
OPENAI_API_KEY="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"
# Optional: override the API endpoint for OpenAI-compatible providers
# Uncomment and set if using a non-OpenAI endpoint:
OPENAI_BASE_URL="https://integrate.api.nvidia.com/v1"
# Database (default is fine for local dev)
DATABASE_URL=sqlite:///./soul_data/db/soul.db
SOUL_DATA_DIR=./soul_data

# LLM model (must match your provider)
LLM_MODEL=minimaxai/minimax-m2.1
LLM_MAX_TOKENS=800

# Mood classification model (must be available to your OpenAI account)
MOOD_OPENAI_MODEL=minimaxai/minimax-m2.1
MOOD_OPENAI_MAX_TOKENS=60
MOOD_OPENAI_TEMPERATURE=0.0

# User and timezone
SOUL_USER_ID=local-user
SOUL_TIMEZONE=Asia/Calcutta
ENVIRONMENT=development
