#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

# Skip merges, squash commits, and amended commits with existing messages
case "$COMMIT_SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

# If message already has content, don't overwrite it
if [ -s "$MSG_FILE" ] && grep -q '[^[:space:]]' "$MSG_FILE"; then
  exit 0
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  echo "chore: update project files" > "$MSG_FILE"
  exit 0
fi

TYPE="chore"
SCOPE=""
SUBJECT="update project files"

if echo "$STAGED_FILES" | grep -qE '(^|/)(test_|tests/|.*test_.*\.py$|.*_test\.py$)'; then
  TYPE="test"
  SUBJECT="update tests"
elif echo "$STAGED_FILES" | grep -qE '(^|/)README\.md$|(^|/)docs/|\.md$'; then
  TYPE="docs"
  SUBJECT="update documentation"
elif echo "$STAGED_FILES" | grep -qE '(^|/)pyproject\.toml$|(^|/)Makefile$|(^|/)\.github/'; then
  TYPE="chore"
  SUBJECT="update project configuration"
else
  TYPE="feat"
  SUBJECT="update runtime behavior"
fi

if echo "$STAGED_FILES" | grep -q '^soul/'; then
  SCOPE="(core)"
elif echo "$STAGED_FILES" | grep -q '^tests/'; then
  SCOPE="(tests)"
elif echo "$STAGED_FILES" | grep -q '^docs/'; then
  SCOPE="(docs)"
elif echo "$STAGED_FILES" | grep -q '^scripts/'; then
  SCOPE="(scripts)"
fi

echo "${TYPE}${SCOPE}: ${SUBJECT}" > "$MSG_FILE"