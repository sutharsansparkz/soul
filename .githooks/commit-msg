#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
MSG="$(head -n1 "$MSG_FILE" | tr -d '\r')"

PATTERN='^(feat|fix|docs|style|refactor|test|chore)(\([a-z0-9._/-]+\))?: .{3,72}$'

if ! printf '%s' "$MSG" | grep -Eq "$PATTERN"; then
  echo "Invalid commit message."
  echo
  echo "Expected format:"
  echo "  type(scope): subject"
  echo
  echo "Examples:"
  echo "  feat(core): add mood snapshot trace"
  echo "  fix(memory): prevent duplicate fact insertion"
  echo "  docs(readme): clarify local setup"
  echo "  chore(ci): update workflow"
  echo
  echo "Allowed types: feat, fix, docs, style, refactor, test, chore"
  exit 1
fi