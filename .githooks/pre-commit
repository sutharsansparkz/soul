#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

if ! command -v python >/dev/null 2>&1 && ! command -v python3 >/dev/null 2>&1; then
  echo "Python is required but was not found on PATH."
  exit 1
fi

# Fast sanity check already supported by your repo
make lint

# Only check staged Python files for syntax errors
STAGED_PY_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.py$' || true)"

if [ -n "$STAGED_PY_FILES" ]; then
  PYTHON_BIN="python"
  command -v python >/dev/null 2>&1 || PYTHON_BIN="python3"

  echo "$STAGED_PY_FILES" | while IFS= read -r file; do
    [ -f "$file" ] || continue
    "$PYTHON_BIN" -m py_compile "$file"
  done
fi

echo "pre-commit passed."